{
  "name": "rfid-v3-backend",
  "version": "1.0.0",
  "private": true,
  "description": "RFID attendance backend with Express API Gateway, gRPC service layer, local retry scheduler, and SQLite persistence.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:grpc\" \"npm:dev:gateway\"",
    "dev:gateway": "nodemon --watch src --ext ts,json,proto --exec tsx src/gateway/server.ts",
    "dev:grpc": "nodemon --watch src --ext ts,json,proto --exec tsx src/grpc/server.ts",
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "start:gateway": "node dist/gateway/server.js",
    "start:grpc": "node dist/grpc/server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.8.0",
    "@types/pdfmake": "^0.3.2",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "pdfmake": "^0.3.8",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "sql.js": "^1.13.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.15.17",
    "@types/sql.js": "^1.4.11",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
